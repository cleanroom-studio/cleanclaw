# E2E provider test env. Copy to `.env` and fill in real values.
# The e2e tests (cleanclaw-e2e/tests/provider.rs) read these
# from the OS env (or .env if you `source` it before running).
#
# `ANTHROPIC_API_KEY` and `OPENAI_API_KEY` are read by the
# provider clients. `ANTHROPIC_BASE_URL` and `OPENAI_BASE_URL`
# are read to point at non-default endpoints (e.g. proxies).
# The real `.env` file is gitignored.

# Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI Chat Completions API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional model overrides (defaults are real-provider
# friendly). Set these to a model your provider actually
# serves. The `.env` shipped with the test repo points at
# `api.minimaxi.com` and the real model name is `MiniMax-M3`.
E2E_ANTHROPIC_MODEL=claude-3-5-haiku-latest
E2E_OPENAI_MODEL=gpt-4o-mini
